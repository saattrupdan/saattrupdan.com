{
  "rewrites": [
    { "source": "/atom.xml", "destination": "/atom.xml" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "trailingSlash" : false,
  "headers": [
    {
      "source": "/atom.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/atom+xml"
        }
      ]
    }
  ]
}
