{
  "rewrites": [
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "trailingSlash" : false,
  "headers": [
    {
      "source": "/atom.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Content-Type",
          "value": "application/atom+xml; charset=utf-8"
        }
      ]
    }
  ]
}
